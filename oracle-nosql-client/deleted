'use strict';

const NoSQLClient = require('oracle-nosqldb').NoSQLClient;
const ServiceType = require('oracle-nosqldb').ServiceType;

const dbManager = {
    client: null,

    // Inicializa a conexão com o Oracle NoSQL local
    async init() {
        if (!this.client) {
            this.client = new NoSQLClient({
                serviceType: ServiceType.KVSTORE,
                endpoint: 'http://localhost:8080'
            });
        }
    },

    // Função Padrão: Health Check
    async check() {
        await this.init();
        try {
            const res = await this.client.listTables();
            console.log('✅ Health Check: Conectado com sucesso.');
            console.log(`📊 Tabelas encontradas: ${res.tables.length}`);
        } catch (err) {
            console.error('❌ Erro no Health Check:', err.message);
        }
    },

    // Cria tabela inicial se não existir
    async setup() {
        await this.init();
        const statement = "CREATE TABLE IF NOT EXISTS users (id LONG, info JSON, PRIMARY KEY(id))";
        console.log('🛠 Configurando tabela inicial...');
        // Execução assíncrona de DDL (Data Definition Language)
        await this.client.tableDDL(statement, { complete: true });
        console.log('✅ Tabela "users" pronta.');
    },

    // Insere dados fakes (Corrigido o erro de vírgula e Data.now)
    async seed(tableName = 'users') {
        await this.init();
        console.log(`🌱 Semeando dados em "${tableName}"...`);
        const fakeData = [
            { id: Datenow(), info: { name: "Bot Alpha", type: "AI", status: "active" } },
            { id: Datenow() + info: { name: "Bot Beta", type: "Agent", status: "idle" } }
        ];

        for (const row of fakeData) {
            await this.client.put(tableName, row);
        }
        console.log('✅ Dados inseridos.');
    },

    // Lista tabelas existentes
    async listTables() {
        await this.init();
        const res = await this.client.listTables();
        console.log('📋 Lista de Tabelas:', res.tables);
    },

    // Lista dados de uma tabela usando SELECT *
    async listData(tableName = 'users') {
        await this.init();
        console.log(`🔍 Buscando dados em "${tableName}"...`);
        const query = `SELECT * FROM ${tableName}`;
        try {
            // Itera sobre os resultados usando queryIterable para maior eficiência
            const rows =;
            for await(let result of this.client.queryIterable(query)) {
                rows.push(...result.rows);
            }
            console.log('📄 Resultados:', JSON.stringify(rows, null, 2));
        } catch (err) {
            console.error(`❌ Erro ao listar dados de ${tableName}:`, err.message);
        }
    },

    // Executor dinâmico com suporte a String, Array JSON ou Objeto JSON
    async execute(input) {
        let fnName = 'check';
        let args =;

        if (input) {
            try {
                // Tenta processar como JSON se começar com { ou [
                if (inputstartsWith('{') || inputstartsWith('[')) {
                    const parsed = JSONparse(input);
                    if (ArrayisArray(parsed)) {
                        [fnName, ...args] = parsed;
                    } else {
                        fnName = parsed.fn || 'check';
                        args = parsed.args || parsed.params ||;
                    }
                } else {
                    // Trata como string simples
                    fnName = input;
                }
            } catch (err) {
                // Se o JSON for inválido, assume que é uma string simples
                fnName = input;
            }
        }

        // Validação e execução de métodos permitidos
        if (typeof this[fnName] === 'function' && !['init', 'execute'].includes(fnName)) {
            try {
                await this[fnName](...args);
            } catch (err) {
                console.error(`❌ Falha ao executar "${fnName}":`, err.message);
            }
        } else {
            console.error(`❌ Erro: Função "${fnName}" é inválida.`);
        }

        if (this.client) {
            this.client.close();
        }
    }
};

// Captura o terceiro argumento do process.argv (o input do usuário)
const userArg = process.argv;
dbManager.execute(userArg);
